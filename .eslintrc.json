{
  "env": {
    "browser": true,
    "es2020": true
  },
  "globals": {
    "CONFIG": "readonly",
    "Utils": "readonly",
    "StateManager": "readonly",
    "Storage": "readonly",
    "DOM": "readonly",
    "Render": "readonly",
    "Toast": "readonly",
    "InputModal": "readonly",
    "DataQuery": "readonly",
    "Business": "readonly",
    "BusinessExclude": "readonly",
    "BusinessFilter": "readonly",
    "BusinessAnalysis": "readonly",
    "BusinessSpecial": "readonly",
    "BusinessSpecialNum": "readonly",
    "BusinessNav": "readonly",
    "BusinessPredict": "readonly",
    "BusinessZodiacTiers": "readonly",
    "BusinessMonitor": "readonly",
    "BusinessHighChase": "readonly",
    "BusinessProbabilityHistory": "readonly",
    "BusinessGemini": "readonly",
    "BusinessBacktest": "readonly",
    "ViewAnalysis": "readonly",
    "ViewFilter": "readonly",
    "ViewExclude": "readonly",
    "ViewSaved": "readonly",
    "ViewPredict": "readonly",
    "ViewZodiacPredict": "readonly",
    "ViewHistory": "readonly",
    "ViewHistoryDetail": "readonly",
    "ViewProbability": "readonly",
    "ViewMe": "readonly",
    "GeminiView": "readonly",
    "initApp": "readonly",
    "initEvent": "readonly"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "no-console": "off",
    "semi": ["warn", "always"],
    "quotes": ["warn", "single", { "avoidEscape": true }],
    "no-multiple-empty-lines": ["warn", { "max": 1 }],
    "no-trailing-spaces": "warn",
    "comma-dangle": ["warn", "only-multiline"],
    "eqeqeq": ["warn", "smart"],
    "no-var": "off"
  },
  "ignorePatterns": [".trae/", "说明文档/"]
}
